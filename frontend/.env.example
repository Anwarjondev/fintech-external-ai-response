# Base URL of the backend API.
# Path prefixes (/api/v1/..., /health) are added by each api/*.ts service,
# so put only the host (and port) here — no trailing /api/v1.
#
# Examples:
#   VITE_API_BASE_URL=http://localhost:8000
#   VITE_API_BASE_URL=https://api.sqb-legal.example.com
VITE_API_BASE_URL=http://localhost:8000
